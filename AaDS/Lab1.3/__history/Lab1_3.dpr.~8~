    TArrayOI = Array Of Integer;

Function ReadAndVerify(Const MIN_NUMBER, MAX_NUMBER: Integer; MyString: String): Integer;
Var
    IsCorrect: Boolean;
    Number: Integer;
Begin
    IsCorrect := True;
    Number := 0;

    Repeat

        Write(MyString);
        IsCorrect := True;

        Try
            ReadLn(Number);
        Except
            WriteLn('Некорректный ввод, повторите снова.');
            IsCorrect := False;
        End;

        If IsCorrect And ( Not((Number >= MIN_NUMBER) And (Number <= MAX_NUMBER)) And Not(Number = 0) ) Then
        Begin
            WriteLn('Число должно входить в диапазон [', MIN_NUMBER, ',', MAX_NUMBER, '] либо равняться 0.');
            IsCorrect := False;
        End;

    Until IsCorrect;

    ReadAndVerify := Number;
End;


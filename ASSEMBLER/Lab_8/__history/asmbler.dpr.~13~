Uses SysUtils;

Type
    TIntArray = Array [0 .. 9] Of Integer;

Procedure WriteAnswers(Var Arr: TIntArray; Size: Integer);
begin
  asm
    push esi
    push edi
    push ebx
    push ecx

    mov  esi, Arr        // адрес массива
    mov  ecx, Size       // счётчик цикла

  @@next:
    mov  eax, [esi]      // загружаем текущий элемент
    xor  edx, edx        // обнуляем edx перед делением
    mov  ebx, 5
    div  ebx             // eax / 5, остаток в edx

    test edx, edx        // проверяем остаток
    jz   @@skip          // если остаток = 0 (кратно 5) — пропускаем

    mov  dword ptr [esi], 0  // НЕ кратно 5 — записываем 0 в массив

  @@skip:
    add  esi, 4          // следующий элемент (Integer = 4 байта)
    loop @@next          // ecx-- и повторяем

    pop  ecx
    pop  ebx
    pop  edi
    pop  esi
  end;
end;

Var
    Arr: TIntArray;
    I: Integer;

Begin
    Randomize;
    For I := 0 To 9 Do
        Arr[I] := Random(999) + 1;

    Write('Массив:          ');
    For I := 0 To 9 Do
        Write(Arr[I]:6);
    WriteLn;

    WriteAnswers(Arr, 10);

    Write('После обработки: ');
    For I := 0 To 9 Do
        If (Arr[I] > 0) Then
            Write(Arr[I]:6);
    WriteLn;

    ReadLn;
End.

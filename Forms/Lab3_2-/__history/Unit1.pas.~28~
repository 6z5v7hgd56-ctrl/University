Function WriteDataToFile(Var SavedFile: TextFile): ERROR_CODES;
Var
    Error: ERROR_CODES;
    MainGridLen, Grid1Len, Grid2Len, I: Integer;
    SortedArray: TArrayOI;
Begin
    Error := NO_ERRORS;
    MainGridLen := MainForm.StringGridA.ColCount;
    Grid1Len := MainForm.StringGridResult1.ColCount;
    Grid2Len := MainForm.StringGridResult2.ColCount;

    Try
        Rewrite(SavedFile);

        WriteLn(SavedFile, MainForm.NumberOneEdit.Text);

        For I := 0 To MainGridLen - 2 Do
        Begin
            Write(SavedFile, MainForm.StringGridA.Cells[I, 1], ' ');
        End;
        WriteLn(SavedFile, MainForm.StringGridA.Cells[MainGridLen - 1, 1]);

        For I := 0 To Grid1Len - 2 Do
        Begin
            Write(SavedFile, MainForm.StringGridResult1.Cells[I, 1], ' ');
        End;
        WriteLn(SavedFile, MainForm.StringGridResult1.Cells[Grid1Len - 1, 1]);

        For I := 0 To Grid2Len - 2 Do
        Begin
            Write(SavedFile, MainForm.StringGridResult2.Cells[I, 1], ' ');
        End;
        Write(SavedFile, MainForm.StringGridResult2.Cells[Grid2Len - 1, 1]);

        CloseFile(SavedFile);
    Except
        Error := FILE_CLOSE_TO_WRITE;
    End;

    WriteDataToFile := Error;
End;

Function  ReadAndWriteOutFileData(Var ReadedFile: TextFile): ERROR_CODES;
Const
    MIN_LENGTH: Integer  = 1;
    MAX_LENGTH: Integer  = 99;
    MAX_ELEMENT: Integer = 255;
    MIN_ELEMENT: Integer = 1;
Var
    Error: ERROR_CODES;
    SetLen, I, Count, Element: Integer;
    SetLenStr, ElementStr: String;
    MainSet, SetOfPrime, SetOfNonPrime: TSet;
Begin
    Error := NO_ERRORS;
    SetLen := 0;
    Element := 0;
    SetLenStr := '';
    ElementStr := '';

    MainSet := [];
    SetOfPrime := [];
    SetOfNonPrime := [];

    Try
        Reset(ReadedFile);
    Except
        Error := FILE_CLOSE_TO_READ;
    End;

    Try
        If EOF(ReadedFile) Then
            Error := (FILE_DATA_NOT_CORRECT);

        ReadLn(ReadedFile, SetLenStr);
        SetLen := StrToInt(SetLenStr);
    Except
        Error := FILE_DATA_NOT_CORRECT;
    End;

    If Error = NO_ERRORS Then
    Begin
        If (SetLen < MIN_LENGTH) Or (SetLen > MAX_LENGTH) Then
        Begin
            Error := FILE_DATA_NOT_CORRECT;
        End
    End;

    If (Error = NO_ERRORS) Then
    Begin
        For I := 0 To SetLen - 1 Do
        Begin
            If Error = NO_ERRORS Then
            Begin
                Element := 0;

                If EOF(ReadedFile) Then
                Begin
                    Error := FILE_DATA_NOT_CORRECT;
                End;

                Try
                    Read(ReadedFile, Element);
                    If (Element > MAX_ELEMENT) Or (Element < MIN_ELEMENT) Then
                        Error := FILE_DATA_NOT_CORRECT
                    Else
                        Include(MainSet, Element)
                Except
                    Error := FILE_DATA_NOT_CORRECT;
                End;
            End;
        End;
    End;

    If Not(EOF(ReadedFile)) Then
    Begin
        Error := FILE_DATA_NOT_CORRECT;
    End;

    CloseFile(ReadedFile);

    If (Error = NO_ERRORS) Then
    Begin
        MainForm.NumberOneEdit.Text := SetLenStr;

        MainForm.LabelResult1.Visible := True;
        MainForm.LabelResult2.Visible := True;
        MainForm.StringGridResult1.Visible := True;
        MainForm.StringGridResult2.Visible := True;

        DivideSet(MainSet, SetOfPrime, SetOfNonPrime);
        SetGridBySet(MainSet, MainForm.StringGridA);
        SetGridBySet(SetOfPrime, MainForm.StringGridResult1);
        SetGridBySet(SetOfNonPrime, MainForm.StringGridResult2);

        MainForm.SaveTab.Enabled := True;
    End;

    ReadAndWriteOutFileData := Error;
End;


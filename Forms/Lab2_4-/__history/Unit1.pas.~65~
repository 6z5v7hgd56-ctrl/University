Function SaveDataToFile(): ERROR_CODES;
Var
    FilePath: String;
    SavedFile: TextFile;
    Error: ERROR_CODES;
    IsToWriteToFile: Boolean;

Begin
    IsToWriteToFile := True;
    Error := ecNO_ERRORS;

    If MainForm.SaveTextFileDialog1.Execute Then
    Begin
        FilePath := MainForm.SaveTextFileDialog1.FileName;

        Try
            AssignFile(SavedFile, FilePath);
            Error := CheckMyFile(SavedFile, FilePath, IsToWriteToFile);
        Except
            Error := ecFILE_ASSIGN_ERROR;
        End;

        If Error = ecNO_ERRORS Then
        Begin
            Error := WriteDataToFile(SavedFile);
        End;

        If Error <> ecNO_ERRORS Then
            Application.MessageBox(PWideChar(ERROR_TEXT[Error]), 'Ошибка', MB_OK + MB_ICONERROR)
        Else
        Begin
            Application.MessageBox(PWideChar('Данные успешно сохранены.'), 'Успешно', MB_OK + MB_ICONINFORMATION);
            IsDataSaved := True;
        End;

    End
    Else
    Begin
        Error := ecFILE_DATA_NOT_SAVED;
    End;

    SaveDataToFile := Error;
End;

Function WriteDataToFile(Var SavedFile: TextFile): ERROR_CODES;
Var
    Error: ERROR_CODES;
    Number, Base, Answer: String;
Begin
    Error := ecNO_ERRORS;
    Number := '';
    Base := '';
    Answer := '';

    // Сбор данных:
    Number := MainForm.EditNumber.Text;
    Base := MainForm.EditNumeralSystem.Text;
    Answer := MainForm.LabelAnswer.Caption;
    //


    Try
        Rewrite(SavedFile);
        CloseFile(SavedFile);
    Except
        Error := ecFILE_CLOSE_TO_WRITE;
    End;

    If Error = ecNO_ERRORS Then
    Begin
        Rewrite(SavedFile);

        // Запись данных:
        WriteLn(SavedFile, Base);
        WriteLn(SavedFile, Number);
        Write(SavedFile, Answer);
        //

        CloseFile(SavedFile);
    End;

    WriteDataToFile := Error;
End;

Function  ReadAndWriteOutFileData(Var ReadedFile: TextFile): ERROR_CODES;
Var
    Error: ERROR_CODES;
    BaseStr, NumberStr: String;
Begin
    Error := ecNO_ERRORS;
    NumberStr := '';
    BaseStr := '';

    Try
        Reset(ReadedFile);
    Except
        Error := ecFILE_CLOSE_TO_READ;
    End;

    If EOF(ReadedFile) Then
        Error := (ecFILE_DATA_NOT_CORRECT);

    Try
        // Считывание первого элемента
        ReadLn(ReadedFile, BaseStr);
        //
    Except
        Error := ecFILE_DATA_NOT_CORRECT;
    End;

    If Not((BaseStr = '2') Or (BaseStr = '8') Or (BaseStr = '10')) Then
        Error := ecFILE_DATA_NOT_CORRECT;

    If Error = ecNO_ERRORS Then
    Begin
        ReadLn(ReadedFile, NumberStr);
        If Not(CheckNumberOnValidity(NumberStr, BaseStr)) Then
            Error := ecFILE_DATA_NOT_CORRECT;
    End;

    // Проверка на лишние данные
    If Not(EOF(ReadedFile)) Then
        Begin
            Error := ecFILE_DATA_NOT_CORRECT;
        End;

    CloseFile(ReadedFile);

    If (Error = ecNO_ERRORS) Then
    Begin
        MainForm.LabelAnswer.Caption := 'Число в 16-й системе счисления: ';
        MainForm.EditNumeralSystem.Text := BaseStr;
        MainForm.EditNumber.Text := NumberStr;

        MainForm.LabelAnswer.Visible := True;

        // Вывод элементов:
        MainForm.LabelAnswer.Caption := MainForm.LabelAnswer.Caption + ConvertNumber(StrToInt64(NumberStr), StrToInt(BaseStr));
        //
    End;

    ReadAndWriteOutFileData := Error;
End;

Procedure TMainForm.FormCloseQuery(Sender: TObject; var CanClose: Boolean);
Begin
    CanClose := LeaveFromProgram(CanClose);
End;

Function TMainForm.FormHelp(Command: Word; Data: THelpEventData; Var CallHelp: Boolean): Boolean;
Begin
    CallHelp := False;
End;

Procedure TMainForm.LeaveTabClick(Sender: TObject);
Begin
    Close;
End;

Function LeaveFromProgram(CanClose: Boolean): Boolean;
Var
    IsFormShouldClose: Integer;
    Error: ERROR_CODES;

Begin
    Error := ecNO_ERRORS;
    CanClose := False;

    If (IsDataSaved) Then
    Begin
        IsFormShouldClose := Application.MessageBox(PChar('Вы хотите выйти?'), PChar('Выход'), MB_YESNO + MB_ICONQUESTION);

        If IsFormShouldClose = mrYes Then
        Begin
            CanClose := True;
        End;
    End
    Else
    Begin
        IsFormShouldClose := Application.MessageBox(PChar('Данные не были сохранены, вы точно хотите выйти?'), PChar('Выход'), MB_YESNOCANCEL + MB_ICONQUESTION);

        If IsFormShouldClose = MrYes Then
            CanClose := True
        Else
            If IsFormShouldClose = MrNo Then
            Begin
                Error := SaveDataToFile();
                If Error = ecNO_ERRORS Then
                    CanClose := True;
            End;

    End;

    LeaveFromProgram := CanClose;
End;

End.

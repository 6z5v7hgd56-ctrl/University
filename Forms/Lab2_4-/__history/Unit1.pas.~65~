Function CheckNumeralSystemNumberOnValidity(TestString: String): Boolean;
Var
    IsStringReadible: Boolean;
    TestInteger: Integer;
Begin
    IsStringReadible := False;

    If Length(TestString) = 0 Then
        IsStringReadible := False
    Else
    Begin
        Try
            TestInteger := StrToInt(TestString);
            If (TestInteger = 10) Or  (TestInteger = 8) Or (TestInteger = 2)  Then
                IsStringReadible := True;
        Except
            IsStringReadible := False;
        End;
    End;

    CheckNumeralSystemNumberOnValidity := IsStringReadible;
End;

Function CheckNumberOnValidity(TestString: String; NumeralSystemStr: String): Boolean;
Const
    MAX_BINARY: Int64 = 1_111_111_111_111_111_111;
    MAX_OCTAL: Int64 = 777_777;
    MAX_DECIMAL: Int64 = 524_286;
    MIN: Int64 = 0;
    DIGITS = ['0' .. '9'];
    BINARY_DIGITS = ['0', '1'];
    OCTAL_DIGITS = ['0' .. '7'];
Var
    IsStringReadible, IsAllDigitsCorrect: Boolean;
    TestInteger: Int64;
    I, NumeralSystem: Integer;
Begin
    IsStringReadible := False;
    IsAllDigitsCorrect := True;
    NumeralSystem := 0;

    If (Length(TestString) = 0) Or (Length(NumeralSystemStr) = 0) Or (TestString[1] = '0') Then
        IsStringReadible := False
    Else
    Begin
        NumeralSystem := StrToInt(NumeralSystemStr);
        IsStringReadible := False;

        Try
            TestInteger := StrToInt64(TestString);
            If (NumeralSystem = 2) And Not((TestInteger < MIN) Or (TestInteger > MAX_BINARY)) Then
                IsStringReadible := True
            Else
                If (NumeralSystem = 8) And Not((TestInteger < MIN) Or (TestInteger > MAX_OCTAL)) Then
                    IsStringReadible := True
                Else
                    If (NumeralSystem = 10) And Not((TestInteger < MIN) Or (TestInteger > MAX_DECIMAL)) Then
                        IsStringReadible := True;
        Except
            IsStringReadible := False;
        End;

        For I := Low(TestString) To High(TestString) Do
        Begin
            If (NumeralSystem = 2) And Not(TestString[I] In BINARY_DIGITS) Then
                IsAllDigitsCorrect := False
            Else
                If (NumeralSystem = 8) And Not(TestString[I] In OCTAL_DIGITS) Then
                    IsAllDigitsCorrect := False
                Else
                    If (NumeralSystem = 10) And Not(TestString[I] In DIGITS) Then
                        IsAllDigitsCorrect := False;
        End;

    End;

    CheckNumberOnValidity := IsStringReadible And IsAllDigitsCorrect;
End;

Procedure FixStringOnInvalidValue(FixedEdit: TEdit; Const NumeralSystem: Integer);
Const
    DIGITS = ['0' .. '9'];
    BINARY_DIGITS = ['0', '1'];
    OCTAL_DIGITS = ['0' .. '7'];
Var
    OnlyNumbersString, EditString: String;
    I, SelStart: Integer;
Begin
    OnlyNumbersString := '';
    EditString := FixedEdit.Text;

    For I := 1 To High(EditString) Do
    Begin
        If (NumeralSystem = 2) And (EditString[I] In BINARY_DIGITS) Then
            OnlyNumbersString := OnlyNumbersString + EditString[I]
        Else
            If (NumeralSystem = 8) And (EditString[I] In OCTAL_DIGITS) Then
                OnlyNumbersString := OnlyNumbersString + EditString[I]
            Else
                If (NumeralSystem = 10) And (EditString[I] In DIGITS) Then
                    OnlyNumbersString := OnlyNumbersString + EditString[I];
    End;

    If OnlyNumbersString <> EditString Then
    Begin
        SelStart := FixedEdit.SelStart;
        FixedEdit.Text := OnlyNumbersString;
        FixedEdit.SelStart := SelStart;
    End;

End;

Procedure TMainForm.EditNumeralSystemKeyPress(Sender: TObject; Var Key: Char);
Var
    WrittenString: String;
    IsKeyAllowed: Boolean;

Begin
    IsKeyAllowed := False;
    WrittenString := EditNumeralSystem.Text;

    //Проверяем ПЕРВЫЙ символ будущей строки
    If (Length(WrittenString) = 0) And ((Key = '2') Or (Key = '8') Or (Key = '1')) Then
        IsKeyAllowed := True;

    If (Length(WrittenString) = 1) And (WrittenString = '1') And (Key = '0') Then
    Begin
        IsKeyAllowed := True;
    End;

    If Key = BACKSPACE Then
        IsKeyAllowed := True;

    If Not IsKeyAllowed Then
        Key := #0;
End;

Procedure TMainForm.EditNumberKeyPress(Sender: TObject; var Key: Char);
Const
    DIGITS = ['0' .. '9'];
    BINARY_DIGITS = ['0', '1'];
    OCTAL_DIGITS = ['0' .. '7'];
Var
    NumeralSystem: Integer;
    WrittenString: String;
    IsKeyAllowed: Boolean;
Begin
    IsKeyAllowed := False;
    WrittenString := EditNumber.Text;
    NumeralSystem := StrToInt(EditNumeralSystem.Text);

    FixStringOnInvalidValue(EditNumber, NumeralSystem);

    If (NumeralSystem = 2) And (Key In BINARY_DIGITS) Then
        IsKeyAllowed := True
    Else
        If (NumeralSystem = 8) And (Key In OCTAL_DIGITS) Then
            IsKeyAllowed := True
        Else
            If (NumeralSystem = 10) And (Key In DIGITS) Then
                IsKeyAllowed := True;

    If (Length(WrittenString) = 0) And (Key = '0') Then
        IsKeyAllowed := False;

    If Key = BACKSPACE Then
        IsKeyAllowed := True;

    If Not IsKeyAllowed Then
        Key := #0;
End;

Procedure TMainForm.EditNumeralSystemChange(Sender: TObject);
Var
    IsNumeralSystemCorrect: Boolean;
    IsNumberCorrect: Boolean;
    NumeralSystem: Integer;
Begin
    IsNumeralSystemCorrect := False;
    IsNumberCorrect := False;

    IsNumeralSystemCorrect := CheckNumeralSystemNumberOnValidity(EditNumeralSystem.Text);

    ResultButton.Enabled := False;
    SaveTab.Enabled := False;
    LabelAnswer.Visible := False;

    If IsNumeralSystemCorrect Then
    Begin
        NumeralSystem := StrToInt(EditNumeralSystem.Text);
        EditNumber.Enabled := True;

        If (NumeralSystem = 2) Then
            MainForm.EditNumber.MaxLength := 19
        Else
            If (NumeralSystem = 8) Or (NumeralSystem = 10) Then
                MainForm.EditNumber.MaxLength := 6;
    End
    Else
    Begin
        EditNumber.Enabled := False;
    End;

    EditNumber.Clear;
End;

Procedure TMainForm.EditNumberChange(Sender: TObject);
Var
    IsNumberCorrect: Boolean;
    Base: Integer;
Begin
    IsNumberCorrect := False;

    If (EditNumeralSystem.Text <> '') Then
    Begin
        Base := StrToInt(EditNumeralSystem.Text);
        IsNumberCorrect := CheckNumberOnValidity(MainForm.EditNumber.Text, MainForm.EditNumeralSystem.Text);
    End
    Else
        IsNumberCorrect := False;

    If IsNumberCorrect Then
    Begin
        ResultButton.Enabled := True;
    End
    Else
    Begin
        ResultButton.Enabled := False;
    End;
End;


    Error := ecNO_ERRORS;

    If OpenTextFileDialog1.Execute Then
    Begin
        FilePath := OpenTextFileDialog1.FileName;

        Try
            AssignFile(OpenedFile, FilePath);
            Error := CheckMyFile(OpenedFile, FilePath, IsToWriteToFile);
        Except

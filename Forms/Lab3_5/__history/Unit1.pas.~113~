Procedure TMainForm.EditSepLengthKeyPress(Sender: TObject; Var Key: Char);
Const
    BACKSPACE = #8;
    DIGITS = ['0' .. '9'];
Var
    WrittenString: String;
    IsKeyAllowed: Boolean;
Begin
    IsKeyAllowed := False;
    WrittenString := EditSepLength.Text;

    //Проверяем ПЕРВЫЙ символ будущей строки
    If ((Length(WrittenString) = 0) And (Key In DIGITS) And Not(Key = '0')) Then
        IsKeyAllowed := True;

    If (Length(WrittenString) > 0) And (Length(WrittenString) < 2) Then
    Begin
        If Key In DIGITS Then
        Begin
            IsKeyAllowed := True;
        End;
    End;

    If Key = BACKSPACE Then
        IsKeyAllowed := True;

    If Not IsKeyAllowed Then
        Key := #0;
End;

Procedure TMainForm.EditStringKeyPress(Sender: TObject; Var Key: Char);
Const
    SG_ALLOWED_KEYS = ['a'..'z', 'A'..'Z', '+', '-', '=', '*', '/', ':', ';', '(', ')', '.', ','];
    DIGITS = ['0'..'9'];
    BACKSPACE = #8;
Var
    WrittenString: String;
    IsKeyAllowed, IsLastFourKeysWasDigits: Boolean;
Begin
    IsKeyAllowed := False;
    IsLastFourKeysWasDigits := False;

    //WrittenString := EditString.Text;

    If ((Length(WrittenString) = 0) And (Key In DIGITS) And (Key <> '0')) Then
        IsKeyAllowed := True;

    If ((Length(WrittenString) > 0) And (Length(WrittenString) < 20) And ((Key In SG_ALLOWED_KEYS) Or (Key In Digits))) Then
        IsKeyAllowed := True;

    If (Length(WrittenString) > 3) Then
    Begin
        IsLastFourKeysWasDigits := (WrittenString[High(WrittenString)] In Digits)
                               And (WrittenString[High(WrittenString)-1] In Digits)
                               And (WrittenString[High(WrittenString)-2] In Digits)
                               And (WrittenString[High(WrittenString)-3] In Digits);
        If (IsLastFourKeysWasDigits) And (Key In DIGITS) Then
            IsKeyAllowed := False;
    End;

    If Key = BACKSPACE Then
        IsKeyAllowed := True;

    If Not IsKeyAllowed Then
        Key := #0;
End;


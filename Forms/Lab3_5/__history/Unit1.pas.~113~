Function CheckLengthStringOnValidity(TestString: String): Boolean;
Var
    IsStringReadible: Boolean;
    TestInteger: Integer;
Begin
    IsStringReadible := False;

    If Length(TestString) = 0 Then
        IsStringReadible := False
    Else
    Begin
        Try
            TestInteger := StrToInt(TestString);
            If (TestInteger >= MIN_ARRAY_LENGTH) And (TestInteger <= MAX_ARRAY_LENGTH) Then
                IsStringReadible := True;
        Except
            IsStringReadible := False;
        End;
    End;

    CheckLengthStringOnValidity := IsStringReadible;
End;

Function CheckStringOnValidity(WrittenString: String): Boolean;
Const
    DIGITS = ['0' .. '9'];
    SG_ALLOWED_KEYS = ['a'..'z', 'A'..'Z', '+', '-', '=', '*', '/', ':', ';', '(', ')', '.', ','];
Var
    IsFirstAndLastCharCorrect, IsNumsInBounds, IsAllCharsCorrect, IsAllGood, IsFiveDigitsInARow: Boolean;
    I: Integer;
Begin
    IsFirstAndLastCharCorrect := False;
    IsNumsInBounds := True;
    IsAllCharsCorrect := True;
    IsAllGood := True;

    If Length(WrittenString) = 0 then
        IsAllGood := False
    Else
    Begin
        IsFirstAndLastCharCorrect := (WrittenString[1] In DIGITS) And (WrittenString[1] <> '0') And (WrittenString[High(WrittenString)] In DIGITS);

        For I := 1 To High(WrittenString) Do
        Begin
            If Not((WrittenString[I] In SG_ALLOWED_KEYS) Or (WrittenString[I] In DIGITS)) Then
                IsAllCharsCorrect := False;

            If I > 4 Then
            Begin
                IsFiveDigitsInARow := (WrittenString[I] In Digits)
                                And (WrittenString[I-1] In Digits)
                                And (WrittenString[I-2] In Digits)
                                And (WrittenString[I-3] In Digits)
                                And (WrittenString[I-3] In Digits);
                If IsFiveDigitsInARow Then
                    IsNumsInBounds := False;
            End;
        End;

        IsAllGood := IsFirstAndLastCharCorrect And IsNumsInBounds And IsAllCharsCorrect;
    End;

    CheckStringOnValidity := IsAllGood;
End;

Function CheckSGStringsOnValidity(SGArray: TArrayOS): Boolean;
Var
    I: Integer;
    IsAllGood, IsStringGood: Boolean;
Begin
    IsAllGood := True;

    If (Length(SGArray) <> 0) Then
        For I := 0 To High(SGArray) Do
        Begin
            IsStringGood := CheckStringOnValidity(SGArray[I]);

            IsAllGood := IsAllGood And IsStringGood;
        End;

    CheckSGStringsOnValidity := IsAllGood;
End;


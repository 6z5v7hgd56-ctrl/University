Function SaveDataToFile(): ERROR_CODES;
Var
    FilePath: String;
    SavedFile: TextFile;
    Error: ERROR_CODES;
    IsToWriteToFile: Boolean;

Begin
    IsToWriteToFile := True;
    Error := EcNO_ERRORS;

    MainForm.SaveTextFileDialog1.Filter := 'Text files (*.txt)|*.txt';

    If MainForm.SaveTextFileDialog1.Execute Then
    Begin
        FilePath := MainForm.SaveTextFileDialog1.FileName;

        Try
            AssignFile(SavedFile, FilePath);
            Error := CheckMyFile(SavedFile, FilePath, IsToWriteToFile);
        Except
            Error := EcFILE_ASSIGN_ERROR;
        End;

        If Error = EcNO_ERRORS Then
        Begin
            Error := WriteDataToFile(SavedFile);
        End;

        If Error <> EcNO_ERRORS Then
            Application.MessageBox(PWideChar(ERROR_TEXT[Error]), 'Ошибка', MB_OK + MB_ICONERROR)
        Else
        Begin
            Application.MessageBox(PWideChar('Данные успешно сохранены.'), 'Успешно', MB_OK + MB_ICONINFORMATION);
            IsDataSaved := True;
        End;

    End
    Else
    Begin
        Error := EcFILE_DATA_NOT_SAVED;
    End;

    SaveDataToFile := Error;
End;

Function WriteDataToFile(Var ToFile: TextFile): ERROR_CODES;
Var
    Error: ERROR_CODES;
    Str, Answer: String;
Begin
    Error := EcNO_ERRORS;
    Str := '';
    Answer := '';

    //Сбор данных:
    Answer := MainForm.LabelResult.Caption;
    Str := MainForm.EditString.Text;
    //

    Try
        Rewrite(ToFile);
        CloseFile(ToFile);
    Except
        Error := EcFILE_CLOSE_TO_WRITE;
    End;

    If Error = EcNO_ERRORS Then
    Begin
        Rewrite(ToFile);

        //Запись данных:
        WriteLn(ToFile, Str);
        Write(ToFile, Answer);
        //

        CloseFile(ToFile);
    End;

    WriteDataToFile := Error;
End;

Function ReadAndWriteOutFileData(Var ReadedFile: TextFile): ERROR_CODES;
Var
    Error: ERROR_CODES;
    Answer, Str: String;
Begin
    Error := EcNO_ERRORS;
    Str := '';
    Answer := '';

    Try
        Reset(ReadedFile);
    Except
        Error := EcFILE_CLOSE_TO_READ;
    End;

    If EOF(ReadedFile) Then
        Error := (EcFILE_DATA_NOT_CORRECT);

    Try
        //Считывание первого элемента
        ReadLn(ReadedFile, Str);
        //
    Except
        Error := EcFILE_DATA_NOT_CORRECT;
    End;

    If Not(CheckEditStringOnValidity(Str)) Then
        Error := EcFILE_DATA_NOT_CORRECT;

    //Проверка на лишние данные
    If Not(EOF(ReadedFile)) Then
    Begin
        Error := EcFILE_DATA_NOT_CORRECT;
    End;

    CloseFile(ReadedFile);

    If (Error = EcNO_ERRORS) Then
    Begin
        MainForm.LabelResult.Caption := 'Выделенная подстрока: ';

        Answer := ExtractInteger(Str);

        //Вывод элементов:
        MainForm.EditString.Text := Str;
        MainForm.LabelResult.Caption := MainForm.LabelResult.Caption + Answer;
        //

        MainForm.LabelResult.Visible := True;
    End;

    ReadAndWriteOutFileData := Error;
End;

